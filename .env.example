# Copy to apps/api/.env and fill in

# LLM provider: "gemini" (default, free tier) or "anthropic" (paid).
LLM_PROVIDER=gemini

# Google Gemini (free tier: 10 req/min for 2.5 Flash, plenty for demos).
# https://aistudio.google.com/apikey — Google account, no card required.
GEMINI_API_KEY=

# Anthropic Claude (paid — $5 minimum credit).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Cohere is used for cross-lingual embeddings (free tier: 1k calls/month).
# https://dashboard.cohere.com/api-keys — sign up, create a trial key.
COHERE_API_KEY=

# Local Postgres (via docker-compose). For cloud deploy use your Neon URLs.
DATABASE_URL=postgresql+asyncpg://echostand:echostand@localhost:5433/echostand
DATABASE_URL_SYNC=postgresql://echostand:echostand@localhost:5433/echostand
# Local Redis (via docker-compose). For cloud deploy use Upstash.
REDIS_URL=redis://localhost:6380/0

# Media storage — leave MINIO_ENDPOINT blank to disable photo/voice upload.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=echostand
MINIO_SECRET_KEY=echostand-secret
MINIO_BUCKET=echostand-media
MINIO_SECURE=false

JWT_SECRET=dev-secret-change-me
# For cross-site deploys (Vercel → Fly.io) set this to your Vercel URL,
# and set COOKIE_SAMESITE=none COOKIE_SECURE=true.
CORS_ORIGINS=http://localhost:3000
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

FUSION_TICK_SECONDS=3
# "cohere" (cloud, free-tier friendly) or "local" (bge-m3, needs torch).
EMBEDDING_BACKEND=cohere
EMBEDDING_MODEL=BAAI/bge-m3
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_REASON=claude-sonnet-5

SUPPORTED_LANGUAGES=en,es,fr,ar,pt,ko
